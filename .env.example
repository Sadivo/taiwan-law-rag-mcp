# ── Provider 選擇 ──────────────────────────────────────────────
# Embedding 內建支援: local | openai | cohere | huggingface | google | mistral | voyageai | bedrock | azure-openai
# Reranking 內建支援: local | cohere | voyageai | flashrank
EMBEDDING_PROVIDER=local
RERANKING_PROVIDER=local

# ── API 金鑰 ────────────────────────────────────────────────────
# 如果 embedding 和 reranking 用同一個 provider，填 PROVIDER_API_KEY 即可
# 如果混搭不同 provider（例如 voyageai + cohere），分別填入各自的金鑰
PROVIDER_API_KEY=
EMBEDDING_API_KEY=
RERANKING_API_KEY=

# 金鑰優先順序：EMBEDDING_API_KEY > PROVIDER_API_KEY > OPENAI_API_KEY / COHERE_API_KEY

# ── 模型設定（選填，留空使用各 Provider 的預設模型）────────────
EMBEDDING_MODEL_NAME=
RERANKING_MODEL_NAME=
EMBEDDING_BATCH_SIZE=100
