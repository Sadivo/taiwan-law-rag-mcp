# ── Provider 選擇 ──────────────────────────────────────────────
# Embedding 內建支援: local | openai | cohere | huggingface | google | mistral | voyageai | bedrock | azure-openai
# Reranking 內建支援: local | cohere | voyageai | flashrank
EMBEDDING_PROVIDER=local
RERANKING_PROVIDER=local

# ── API 金鑰 ────────────────────────────────────────────────────
# 如果 embedding 和 reranking 用同一個 provider，填 PROVIDER_API_KEY 即可
# 如果混搭不同 provider（例如 voyageai + cohere），分別填入各自的金鑰
PROVIDER_API_KEY=
EMBEDDING_API_KEY=
RERANKING_API_KEY=

# 金鑰優先偵測EMBEDDING_API_KEY，後PROVIDER_API_KEY

# ── 模型設定（選填，留空使用各 Provider 的預設模型）────────────
EMBEDDING_MODEL_NAME=
RERANKING_MODEL_NAME=
EMBEDDING_BATCH_SIZE=100

# ── 伺服器設定 ──────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8073

# ── Generation Provider ─────────────────────────────────────────
# 支援: ollama | openai | anthropic（預設 ollama）
GENERATION_PROVIDER=ollama

# openai / anthropic 需要填入 API 金鑰
GENERATION_API_KEY=

# 覆寫預設模型（ollama: qwen3:8b, openai: gpt-4o-mini, anthropic: claude-3-5-haiku-20241022）
GENERATION_MODEL_NAME=

# retrieval 預設 top_k（預設 5）
GENERATION_TOP_K=5

# LLM 最大生成 token 數（預設 1024）
GENERATION_MAX_TOKENS=1024

# Ollama 服務位址（預設 http://localhost:11434）
OLLAMA_BASE_URL=http://localhost:11434
